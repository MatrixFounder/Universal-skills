# skill-auto-improve — environment template.
# Copy to `.env` at the skill root (this directory) and fill in what you use.
# Loaded from the skill root and the current working directory (NOT parent
# directories — see SKILL.md §5 trust boundary). The CWD .env is trusted input.
# Provider SDKs are imported lazily: you only need the one you select below.

# ── Provider selection ──────────────────────────────────────────────────────
# Which LLM backend the loop talks to. One of: gemini | anthropic | openai.
DEFAULT_PROVIDER=anthropic

# ── API keys (set the one matching DEFAULT_PROVIDER) ────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── OpenAI-compatible gateways (optional) ───────────────────────────────────
# Point the OpenAI client at a gateway / local server (OpenRouter, Hermes,
# Ollama, vLLM, Together, Groq, LiteLLM, ...). When set with
# DEFAULT_PROVIDER=openai, the run prints a WARNING (all prompts go there).
# Leave blank for api.openai.com.
# OPENAI_BASE_URL=http://localhost:1234/v1
# Optional custom headers for the OpenAI client, as JSON (e.g. OpenRouter
# attribution for leaderboard ranking — NOT required for OpenRouter to work):
# OPENAI_DEFAULT_HEADERS={"HTTP-Referer":"https://your-app","X-Title":"skill-auto-improve"}

# ── OpenRouter recipe (it is OpenAI-compatible) ─────────────────────────────
# OpenRouter routes to Anthropic / OpenAI / Google / Llama / etc. behind one
# OpenAI-compatible endpoint. Use the openai provider and set the model via
# OPENAI_MODEL_OVERRIDE to an OpenRouter model id ("vendor/model"):
#   DEFAULT_PROVIDER=openai
#   OPENAI_API_KEY=sk-or-v1-...                       # your OpenRouter key
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL_OVERRIDE=anthropic/claude-3.5-sonnet # the model "link"; applies to all profiles
#   # OPENAI_FALLBACK_MODELS=openai/gpt-4o,meta-llama/llama-3.1-70b-instruct
# For a DIFFERENT OpenRouter model per profile (proposer/grader/text_mutator),
# edit each profile's `openai:` model in config/llm_profiles.yaml to an
# OpenRouter id instead of using OPENAI_MODEL_OVERRIDE.

# ── Anthropic-compatible gateway (optional) ─────────────────────────────────
# For an Anthropic-compatible proxy when DEFAULT_PROVIDER=anthropic.
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy/v1

# ── Per-provider model overrides (optional) ─────────────────────────────────
# Override the model from config/llm_profiles.yaml WITHOUT editing the yaml.
# Applies to all profiles for the active provider. Use {PROVIDER}_MODEL_OVERRIDE.
# ANTHROPIC_MODEL_OVERRIDE=claude-opus-4-8
# OPENAI_MODEL_OVERRIDE=gpt-5.2
# GEMINI_MODEL_OVERRIDE=gemini-2.5-pro

# Fallback model chain (comma-separated) tried on retryable errors (429/timeout).
# OPENAI_FALLBACK_MODELS=gpt-4o,gpt-4o-mini
# ANTHROPIC_FALLBACK_MODELS=claude-haiku-4-5-20251001
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash

# ── Generation / request tuning (optional) ──────────────────────────────────
# Per-call output-token cap for ALL profiles (same as CLI --max-output-tokens;
# overrides max_output_tokens in llm_profiles.yaml). Leave unset to use the yaml.
# LLM_MAX_OUTPUT_TOKENS=8192
# Request timeout (seconds) and OpenAI client-level retries.
# LLM_REQUEST_TIMEOUT_SECONDS=180
# LLM_OPENAI_CLIENT_RETRIES=1

# ── Agent-eval backend (skill-trigger eval, capability B) ───────────────────
# Force the vendor instead of auto-detecting (claude | gemini | codex | fallback).
# Only `claude` is a validated backend; others fall back to LLM-only grading.
# AUTO_IMPROVE_VENDOR=claude
# Explicit path to skill-creator's run_eval.py (must be a .py file). Default:
# the sibling skills/skill-creator/scripts/run_eval.py is auto-located.
# AUTO_IMPROVE_RUN_EVAL=/abs/path/to/skill-creator/scripts/run_eval.py
