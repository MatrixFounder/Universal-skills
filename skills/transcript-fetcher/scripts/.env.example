# transcript-fetcher — skill-local configuration template.
#
# Copy this file to `.env` (in THIS directory or one level up at the skill root)
# and fill in the values you need. EVERYTHING here is optional — with no `.env`
# at all the skill uses the built-in defaults and local ASR tools.
#
#   cp .env.example .env
#   chmod 600 .env            # REQUIRED — see "Secret storage" below
#
# Resolution order (first wins): CLI flag → real env var → this `.env` → default.
# A real environment variable ALWAYS overrides a value here.
#
# ─── Secret storage (IMPORTANT) ──────────────────────────────────────────────
# `.env` may hold an API key. The loader REFUSES to read it unless it is
# `chmod 600` (owner-only) and not a symlink — a group/world-readable `.env` is
# ignored with a stderr warning. `.env` is git-ignored; only this `.env.example`
# (placeholders, no secrets) is committed. Secrets are sent to the network
# backend in an HTTP Authorization header only — never on a command line, never
# logged. Disable `.env` loading entirely with TRANSCRIPT_FETCHER_NO_DOTENV=1.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloud ASR backend (OpenAI Whisper API or ANY OpenAI-compatible server) ──
# The cloud backend is OPT-IN: it is only used when `--asr-allow-cloud` is passed
# (or TRANSCRIPT_FETCHER_ASR_ALLOW_CLOUD=1 below) AND a key is present.

# API key / bearer token. The conventional unprefixed OPENAI_API_KEY also works.
# TRANSCRIPT_FETCHER_OPENAI_API_KEY=sk-...

# Point at an OpenAI-compatible server (Groq, a self-hosted whisper server, an
# internal gateway). Base URL is combined with the transcribe path below.
# TRANSCRIPT_FETCHER_OPENAI_BASE_URL=https://api.openai.com/v1
# TRANSCRIPT_FETCHER_OPENAI_TRANSCRIBE_PATH=/audio/transcriptions

# …or override the FULL transcription URL verbatim (ignores base+path above):
# TRANSCRIPT_FETCHER_OPENAI_TRANSCRIBE_ENDPOINT=https://api.groq.com/openai/v1/audio/transcriptions

# Default cloud model (CLI --asr-model overrides). e.g. whisper-1, whisper-large-v3.
# TRANSCRIPT_FETCHER_OPENAI_MODEL=whisper-1

# Max audio size (MiB) uploaded to the cloud backend; the request fails fast
# above it instead of buffering. Default 25 (the OpenAI limit). Raise for a
# compatible server with a bigger limit, or 0 to disable the client-side check.
# TRANSCRIPT_FETCHER_OPENAI_MAX_UPLOAD_MB=25

# Enable the cloud backend by default without passing --asr-allow-cloud each time.
# TRANSCRIPT_FETCHER_ASR_ALLOW_CLOUD=0

# ── ASR behaviour ───────────────────────────────────────────────────────────
# Per-backend transcription timeout in seconds (default 1800).
# TRANSCRIPT_FETCHER_ASR_TIMEOUT_SEC=1800

# Default model for ALL backends (CLI --asr-model overrides). For MacWhisper use
# the `engine:model-id` form; for whisper.cpp this is the path to a ggml-*.bin.
# TRANSCRIPT_FETCHER_ASR_MODEL=

# ── Silence removal before ASR (X path) ─────────────────────────────────────
# Before transcribing, ffmpeg `silenceremove` strips leading silence and collapses
# long interior/trailing gaps — this cuts Whisper hallucinated filler (e.g.
# "Продолжение следует...") on silent lead-in/out. ON by default; --keep-silence
# (or =0 here) turns it off. NOTE: only TRUE silence is removed — a music-only
# intro carries energy and survives (see KNOWN_ISSUES TF-X-6).
# TRANSCRIPT_FETCHER_SILENCE_REMOVAL=1
# Loudness gate below which audio counts as silence ("-45dB" or a bare "-45").
# TRANSCRIPT_FETCHER_SILENCE_THRESHOLD=-45dB
# Only silences longer than this many seconds are collapsed (shorter pauses kept).
# TRANSCRIPT_FETCHER_SILENCE_MIN_GAP_SEC=1.0
# Seconds of silence to leave where a long gap is collapsed (keeps a sentence break).
# TRANSCRIPT_FETCHER_SILENCE_KEEP_SEC=0.3

# ── External tool binary overrides (use a non-standard install path) ────────
# TRANSCRIPT_FETCHER_MW_BIN=mw
# TRANSCRIPT_FETCHER_WHISPER_BIN=whisper
# TRANSCRIPT_FETCHER_WHISPER_CPP_BIN=whisper-cli
# TRANSCRIPT_FETCHER_FFMPEG_BIN=ffmpeg
# TRANSCRIPT_FETCHER_FFPROBE_BIN=ffprobe

# ── Per-host cookies (auth-walled media) ────────────────────────────────────
# Path to a JSON auth-map: { "x.com": {"cookies_file": "~/.transcript-fetcher/x.txt"} }.
# Default (if unset): ~/.transcript-fetcher/auth-map.json. The convention
# ~/.transcript-fetcher/<host>-cookies.txt also works with no map. Files must be
# chmod 600 (not a symlink). --cookies-file always overrides.
# TRANSCRIPT_FETCHER_AUTH_MAP=~/.transcript-fetcher/auth-map.json

# ── Misc ────────────────────────────────────────────────────────────────────
# Stage logging to stderr (same as --debug).
# TRANSCRIPT_FETCHER_DEBUG=0
# Disable skill-local .env loading entirely.
# TRANSCRIPT_FETCHER_NO_DOTENV=0
