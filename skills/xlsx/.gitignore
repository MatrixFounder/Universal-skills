# xlsx skill — local runtime artifacts

# Python — populated by `python3 -m venv scripts/.venv`
scripts/.venv/
scripts/__pycache__/
scripts/office/__pycache__/
scripts/office/**/__pycache__/
scripts/*.pyc

# OOXML schema bundles — fetched on demand by scripts/office/schemas/fetch.sh.
# Only W3C xml.xsd, schemas/README.md, and fetch.sh are committed.
scripts/office/schemas/.tmp/
scripts/office/schemas/ecma-376/
scripts/office/schemas/microsoft/

# Compiled AF_UNIX shim — built on demand by office/shim/build.sh
scripts/office/shim/liblo_socket_shim.so
scripts/office/shim/liblo_socket_shim.dylib
scripts/office/shim/*.o
scripts/office/shim/.build.lock

# User-produced outputs from ad-hoc runs
*.xlsx
!examples/**/*.xlsx
# Committed golden-diff baselines for xlsx_add_comment regression tests.
# Without this exception the blanket `*.xlsx` rule above swallows them,
# CI clones the repo without the goldens, and the xlsx_add_comment
# goldens block fails with FileNotFoundError. The golden INPUTS live
# under a sibling tests/golden/inputs/.gitignore with its own rules
# (synthetic fixtures are gitignored and regenerated by test_e2e.sh).
!scripts/tests/golden/outputs/*.golden.xlsx

# OS cruft
.DS_Store
